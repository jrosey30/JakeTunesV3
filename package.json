{
  "name": "JakeTunes",
  "productName": "JakeTunes",
  "version": "3.0.0",
  "description": "Pixel-perfect iTunes 7 replica — 2006 visuals, 2026 brain",
  "author": "Jacob Rosenbaum",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:dmg": "electron-vite build && electron-builder --mac dmg",
    "release": "electron-vite build && electron-builder --mac --publish always",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release"
  },
  "build": {
    "appId": "com.jacobrosenbaum.jaketunes",
    "productName": "JakeTunes",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "jrosey30",
      "repo": "JakeTunesV3"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JakeTunes"
    },
    "dmg": {
      "title": "JakeTunes Installer",
      "iconSize": 80,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "out/**/*",
      "core/**/*",
      "!core/__pycache__/**"
    ],
    "extraResources": [
      {
        "from": "core",
        "to": "core"
      }
    ],
    "asar": true
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "howler": "^2.2.4",
    "music-metadata": "^11.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/howler": "^2.2.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}

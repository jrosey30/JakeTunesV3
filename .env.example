# JakeTunes requires three API keys to run.
# Copy this file to `.env` and fill in your own keys.
# Never commit your real `.env` file — it is already in .gitignore.

# Anthropic — powers The Music Man's commentary and playlist picks.
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# ElevenLabs — HIGHLY RECOMMENDED but optional. Powers The Music Man's
# voice. Without this key:
#   - Music Man is text-only (no spoken responses)
#   - DJ Mode is DISABLED entirely (the continuous spoken DJ set feature
#     requires voice — it does not work without ElevenLabs)
# The rest of the app (playback, library, CD import, iPod sync, AI chat,
# AI playlist builder, daily picks with written commentary) works fine.
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# OPTIONAL — override the default Music Man voice with one of your own.
# Leave blank to use the default voice baked into the code. To use a voice
# from the ElevenLabs Voice Library, add it to your library first at
# https://elevenlabs.io/app/voice-library, then paste its ID here.
# To use a voice you cloned yourself, paste that voice's ID here.
ELEVENLABS_VOICE_ID=

# Discogs — OPTIONAL. Pulls your vinyl collection into The Music Man's
# taste profile so it references the records you actually own. Also
# powers Discogs pressing detail in radio chatter (label, year, country,
# format) so MM can drop record-store-snob context naturally.
# Get a token: https://www.discogs.com/settings/developers
DISCOGS_API_TOKEN=your_discogs_token_here

# 4.3.0 — RADIO SHOW ENRICHMENT (all OPTIONAL):
# Without these the radio show still works, just with less external
# context to react to. Each is fail-soft — if a key is missing or the
# API blips, the prompt just skips that source.

# OpenWeatherMap — adds Brooklyn weather to the radio prompt so MM and
# Megan can drop "live from a 36-degree drizzle" type real-radio context.
# Get a free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Last.fm — pulls weekly US scrobble charts (what's actually trending
# right now) and "similar to" data. Used in radio chatter and as a
# pulse-check for picks generation. Free key.
# Get a key: https://www.last.fm/api/account/create
LASTFM_API_KEY=
